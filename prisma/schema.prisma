generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Case {
  id         String   @id @default(cuid())
  title      String
  area       String?
  /// Allowed values: draft, active, closed.
  status     String   @default("draft")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  documents      Document[]
  journal_items  JournalItem[]
  chat_messages  ChatMessage[]
  ai_suggestions AISuggestion[]
  situations     Situation[]
}

model Situation {
  id            String   @id @default(cuid())
  case_id       String
  title         String
  description   String?
  /// Allowed values: active, archived.
  status        String   @default("active")
  display_order Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  case                Case                @relation(fields: [case_id], references: [id], onDelete: Cascade)
  goals               Goal[]
  situation_documents SituationDocument[]

  @@index([case_id])
  @@index([case_id, display_order])
}

model Goal {
  id            String   @id @default(cuid())
  situation_id  String
  title         String
  /// Allowed values: active, completed, archived.
  status        String   @default("active")
  display_order Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  situation Situation @relation(fields: [situation_id], references: [id], onDelete: Cascade)

  @@index([situation_id])
  @@index([situation_id, display_order])
}

model Document {
  id                String   @id @default(cuid())
  case_id           String
  filename          String
  filetype          String
  original_file     String

  extracted_text      String?
  processed_text      String?
  processed_markdown  String?
  processing_status   String @default("processed")
  processing_error    String?
  markdown_version    Int @default(1)

  validation_status   String @default("pending_validation")

  ai_summary        String?
  created_at        DateTime @default(now())

  case                Case                @relation(fields: [case_id], references: [id], onDelete: Cascade)
  situation_documents SituationDocument[]
  annotations         DocumentAnnotation[]
  pins                DocumentPin[]

  @@index([case_id])
}

model DocumentAnnotation {
  id              String   @id @default(cuid())
  document_id     String
  selected_text   String
  start_offset    Int?
  end_offset      Int?
  annotation_type String   @default("note")
  highlight_color String?
  note_text       String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  document Document @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
  @@index([document_id, annotation_type])
}

model DocumentPin {
  id            String   @id @default(cuid())
  document_id   String
  selected_text String
  start_offset  Int
  end_offset    Int
  visual_offset        Int?
  case_bookmark_number Int?
  color                String   @default("red")
  note_text     String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  document Document @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
  @@index([document_id, start_offset])
  @@index([case_bookmark_number])
}

model SituationDocument {
  id           String   @id @default(cuid())
  situation_id String
  document_id  String
  created_at   DateTime @default(now())

  situation Situation @relation(fields: [situation_id], references: [id], onDelete: Cascade)
  document  Document  @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([situation_id])
  @@index([document_id])
  @@unique([situation_id, document_id])
}

model JournalItem {
  id                String   @id @default(cuid())
  case_id           String
  /// Allowed values: description, goals, risks, open_questions, strategy.
  section           String
  /// Allowed values: FACT, CLAIM, GOAL, QUESTION, ACTION, RISK.
  item_type         String
  title             String
  value             String?
  explanation       String?
  /// Allowed values: verified, inferred, unverified, conflict.
  evidence_state    String   @default("unverified")
  /// Allowed values: active, resolved, obsolete.
  status            String   @default("active")
  display_order     Int      @default(0)
  source_links_json String   @default("[]")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  case Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@index([case_id, section, display_order])
}

model ChatMessage {
  id         String   @id @default(cuid())
  case_id    String
  role       String
  content    String
  created_at DateTime @default(now())

  case Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id, created_at])
}

model AISuggestion {
  id                  String   @id @default(cuid())
  case_id             String
  /// Allowed values: pending, approved, rejected.
  status              String   @default("pending")
  suggested_item_json String
  assistant_reply     String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  case Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id, status])
}
