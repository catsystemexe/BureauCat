generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CaseStatus {
  draft
  active
  closed
}

enum JournalSection {
  description
  goals
  risks
  open_questions
  strategy
}

enum JournalItemType {
  FACT
  CLAIM
  GOAL
  QUESTION
  ACTION
  RISK
}

enum EvidenceState {
  verified
  inferred
  unverified
  conflict
}

enum JournalItemStatus {
  active
  resolved
  obsolete
}

enum AISuggestionStatus {
  pending
  approved
  rejected
}

model Case {
  id         String     @id @default(cuid())
  title      String
  area       String?
  status     CaseStatus @default(draft)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  documents      Document[]
  journal_items  JournalItem[]
  chat_messages  ChatMessage[]
  ai_suggestions AISuggestion[]
}

model Document {
  id             String   @id @default(cuid())
  case_id        String
  filename       String
  filetype       String
  original_file  String
  extracted_text String?
  ai_summary     String?
  created_at     DateTime @default(now())

  case Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
}

model JournalItem {
  id                String            @id @default(cuid())
  case_id           String
  section           JournalSection
  item_type         JournalItemType
  title             String
  value             String?
  explanation       String?
  evidence_state    EvidenceState      @default(unverified)
  status            JournalItemStatus  @default(active)
  display_order     Int
  source_links_json String             @default("[]")
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  case Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@index([case_id, section, display_order])
}

model ChatMessage {
  id         String   @id @default(cuid())
  case_id    String
  role       String
  content    String
  created_at DateTime @default(now())

  case Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id, created_at])
}

model AISuggestion {
  id                  String             @id @default(cuid())
  case_id             String
  status              AISuggestionStatus @default(pending)
  suggested_item_json String
  assistant_reply     String?
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  case Case @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id, status])
}
